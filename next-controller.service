[Unit]
Description=Next Controller
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/mnt/nvme/next-controller
Environment=PYTHONUNBUFFERED=1
ExecStart=/mnt/nvme/next-controller/.venv/bin/uvicorn app.main:app --host 0.0.0.0 --port 3000
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
